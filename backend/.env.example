# Keystone Backend Environment Configuration

PORT=4000

# Supabase Connections
SUPABASE_URL=YOUR_SUPABASE_DATABASE_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Soroban Testnet Connections
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE='Test SDF Network ; September 2015'

# [!WARNING] - CRITICAL DEPENDENCY BOUND
# ESCROW_CONTRACT_ID must physically match EXACTLY the `NEXT_PUBLIC_ESCROW_ID` mapping 
# inside `frontend/.env.local`. If the rust contract is ever actively re-deployed 
# across chains, BOTH variables must be independently updated to avoid ownership verification drifts!
ESCROW_CONTRACT_ID=YOUR_ACTIVE_ESCROW_CONTRACT_DEPLOYMENT_ID
